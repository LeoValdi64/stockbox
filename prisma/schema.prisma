generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  name      String?
  createdAt DateTime @default(now())

  products   Product[]
  sales      Sale[]
  categories Category[]
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  barcode     String?
  quantity    Int      @default(0)
  minStock    Int?
  category    String?
  imageUrl    String?
  costPrice   Float?
  salePrice   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  saleItems SaleItem[]

  @@unique([userId, barcode])
  @@index([userId])
}

model Sale {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  total     Float
  notes     String?

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items SaleItem[]

  @@index([userId])
}

model SaleItem {
  id          String @id @default(cuid())
  saleId      String
  productId   String
  quantity    Int
  priceAtSale Float

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model Category {
  id     String  @id @default(cuid())
  userId String
  name   String
  color  String?
  icon   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}
